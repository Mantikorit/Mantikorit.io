{
  // ОСНОВНЫЕ НАСТРОЙКИ
  "starsCount": 400,         // Общее количество звезд на фоне (рекомендуется 200-800)
  
  "nebulae": [],             // Массив предопределенных туманностей (если пустой - генерируются автоматически)
  
  "parallax": {              // Настройки параллакс-эффекта (движение фона при перемещении курсора)
    "intensity": 30,         // Сила реакции на движение мыши (1-100)
    "smoothness": 0.1,       // Плавность анимации (0.01-0.2, меньше = плавнее)
    "maxOffset": 50,         // Максимальное смещение фона в пикселях
    "enabled": true,         // Включение/отключение эффекта
    "xAxis": true,           // Реакция на движение по горизонтали
    "yAxis": true,           // Реакция на движение по вертикали
    "inverted": false,       // Инверсия направления движения (true = противоположно курсору)
    "scaleFactor": 1.0       // Множитель интенсивности (0.5-2.0)
  },
  
  "colors": {                // Базовые цвета фона
    "primaryGradient": "#1a0a2e",    // Основной цвет градиента (темно-фиолетовый)
    "secondaryGradient": "#0f0523",  // Вторичный цвет градиента (очень темный фиолетовый)
    "tertiaryGradient": "#2d0b50",   // Акцентный цвет градиента (насыщенный фиолетовый)
    "bgColor": "#000000"             // Цвет фона вне градиента (черный)
  },
  
  "stars": {                 // Параметры генерации звезд
    "minSize": 0.5,          // Минимальный размер звезды в пикселях
    "maxSize": 2.5,          // Максимальный размер звезды
    "minOpacity": 0.2,       // Минимальная видимость звезды (0-1)
    "maxOpacity": 0.7,       // Максимальная видимость звезды
    "minDuration": 3,        // Минимальная длительность анимации мерцания (секунды)
    "maxDuration": 10        // Максимальная длительность анимации
  },
  
  "animations": {            // Настройки анимаций
    "fadeInDuration": 2000,  // Длительность плавного появления фона (миллисекунды)
    "starsChangeDuration": 1000 // Длительность изменения звезд (для будущих функций)
  },
  
  "nebulaeSettings": {       // Параметры генерации туманностей
    "minCount": 1,           // Минимальное количество туманностей
    "maxCount": 5,           // Максимальное количество
    "minSize": 100,          // Минимальный диаметр в пикселях
    "maxSize": 400,          // Максимальный диаметр
    "minBlur": 20,           // Минимальное размытие краев
    "maxBlur": 100,          // Максимальное размытие
    "minOpacity": 0.1,       // Минимальная видимость
    "maxOpacity": 0.5        // Максимальная видимость
  },
  
  // НАСТРОЙКИ КОМЕТ
  "comets": {
    "count": 3,              // Общее количество комет на сцене
    "minDelay": 1000,        // Минимальная задержка перед появлением (мс)
    "maxDelay": 5000,        // Максимальная задержка
    "minLength": 80,         // Минимальная длина хвоста
    "maxLength": 200,        // Максимальная длина
    "minThickness": 1,       // Минимальная толщина кометы
    "maxThickness": 4        // Максимальная толщина
  },
  
  // ЦВЕТОВЫЕ СХЕМЫ ЭЛЕМЕНТОВ
  "nebulaColorSchemes": [    // Палитры для туманностей
    { 
      "name": "Фиолетовая", 
      "colors": ["#8c2a5d", "#5d2a8c", "#8c5a7a"] // Оттенки фиолетового и пурпурного
    },
    { 
      "name": "Синяя", 
      "colors": ["#2a5d8c", "#5a8c8c", "#2a8c5d"] // Оттенки синего и бирюзового
    },
    { 
      "name": "Теплая", 
      "colors": ["#8c5d2a", "#5d8c2a", "#8c2a2a"] // Теплые оттенки: коричневый, зеленый, красный
    }
  ],
  
  "starColorSchemes": [      // Палитры для звезд
    { 
      "name": "Белая", 
      "colors": ["#ffffff", "#f0f0f0", "#e0e0e0"] // Белые и серые оттенки
    },
    { 
      "name": "Золотая", 
      "colors": ["#ffeb3b", "#ffc107", "#ff9800"] // Золотисто-желтые оттенки
    },
    { 
      "name": "Голубая", 
      "colors": ["#03a9f4", "#00bcd4", "#4fc3f7"] // Голубые и бирюзовые оттенки
    }
  ],
  
  "cometColorSchemes": [     // Палитры для комет
    { 
      "name": "Белая", 
      "colors": ["#ffffff"]  // Чисто белый цвет
    },
    { 
      "name": "Синяя", 
      "colors": ["#2196f3", "#03a9f4", "#00bcd4"] // Синие оттенки
    },
    { 
      "name": "Красная", 
      "colors": ["#f44336", "#e91e63", "#ff5722"] // Красные и оранжевые оттенки
    }
  ],
  
  // ЦВЕТОВЫЕ СХЕМЫ ФОНА (связанные наборы)
  "colorSchemes": [
    {
      "name": "Фиолетовая",
      "primaryGradient": "#1a0a2e",
      "secondaryGradient": "#0f0523",
      "tertiaryGradient": "#2d0b50",
      "bgColor": "#000000",
      "linkedNebulaSchemes": ["Фиолетовая", "Синяя"],  // Связанные схемы туманностей
      "linkedStarSchemes": ["Белая"],                 // Связанные схемы звезд
      "linkedCometSchemes": ["Синяя"]                 // Связанные схемы комет
    },
    {
      "name": "Голубая",
      "primaryGradient": "#0a1a2e",    // Темно-синий градиент
      "secondaryGradient": "#051223",  // Очень темный синий
      "tertiaryGradient": "#0b2d50",   // Насыщенный синий
      "bgColor": "#000011",            // Почти черный с синим оттенком
      "linkedNebulaSchemes": ["Синяя"],
      "linkedStarSchemes": ["Голубая"],
      "linkedCometSchemes": ["Белая"]
    },
    {
      "name": "Красная",
      "primaryGradient": "#2e0a0a",    // Темно-красный градиент
      "secondaryGradient": "#230505",  // Очень темный красный
      "tertiaryGradient": "#500b0b",   // Насыщенный бордовый
      "bgColor": "#110000",            // Почти черный с красным оттенком
      "linkedNebulaSchemes": ["Теплая", "Фиолетовая"],
      "linkedStarSchemes": ["Золотая"],
      "linkedCometSchemes": ["Красная"]
    },
    {
      "name": "Зеленая",
      "primaryGradient": "#0a2e1a",    // Темно-зеленый градиент
      "secondaryGradient": "#052312",  // Очень темный зеленый
      "tertiaryGradient": "#0b502d",   // Насыщенный изумрудный
      "bgColor": "#001100",            // Почти черный с зеленым оттенком
      "linkedStarSchemes": ["Белая"],  // Нет связанных туманностей
      "linkedCometSchemes": ["Белая"]
    },
    {
      "name": "Золотая",
      "primaryGradient": "#2e1a0a",    // Темно-коричневый градиент
      "secondaryGradient": "#231205",  // Очень темный коричневый
      "tertiaryGradient": "#503d0b",   // Насыщенный золотисто-коричневый
      "bgColor": "#110d00",            // Почти черный с коричневым оттенком
      "linkedStarSchemes": ["Золотая"],
      "linkedCometSchemes": ["Красная"]
    }
  ]
}